---
import BaseLayout from "../layouts/BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { AUTHOR } from "../consts";
import {
  awayFromKeyboard,
  careerLocation,
  careerSummary,
  experience,
  expertise,
  jobSlug,
  openSource,
  skills,
} from "../data/career";

const headings = [
  { depth: 2, slug: "areas-of-expertise", text: "Areas of Expertise" },
  { depth: 2, slug: "experience", text: "Experience" },
  ...experience.flatMap((job) => {
    if (!job.roles?.length) {
      return [
        {
          depth: 3,
          slug: jobSlug(job),
          text: job.team ? `${job.company} ${job.team}` : job.company,
        },
      ];
    }
    return [
      { depth: 3, slug: jobSlug(job), text: job.company },
      ...job.roles.map((role) => ({
        depth: 4,
        slug: jobSlug(job, role),
        text: role.team,
      })),
    ];
  }),
  { depth: 2, slug: "skills", text: "Skills" },
  { depth: 2, slug: "open-source--community", text: "Open Source & Community" },
];
---

<BaseLayout
  title="About"
  description={`About ${AUTHOR.name} — ${careerSummary}`}
>
  <div class="container-page">
    <div class="mx-auto max-w-6xl xl:grid xl:grid-cols-[minmax(0,1fr)_220px] xl:gap-12">
      <article class="mx-auto max-w-3xl xl:mx-0 xl:max-w-none">
        <header class="flex flex-col gap-6 sm:flex-row sm:items-end">
          <img
            src={AUTHOR.avatar}
            alt={AUTHOR.name}
            class="h-28 w-28 rounded-full object-cover ring-1 ring-[var(--color-border)]"
            width="112"
            height="112"
            loading="eager"
            decoding="async"
          />
          <div>
            <h1 class="font-sans text-3xl font-semibold tracking-tight sm:text-4xl">
              About
            </h1>
            <p class="mt-2 max-w-2xl text-[var(--color-muted)] leading-relaxed">
              {careerSummary}
            </p>
          </div>
        </header>

        <div
          class="mt-8 flex flex-wrap gap-x-6 gap-y-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-code-bg)] px-4 py-3 text-sm"
        >
          <span class="text-[var(--color-muted)]">{careerLocation}</span>
          <a
            href={`https://www.linkedin.com/in/${AUTHOR.linkedin}`}
            class="text-[var(--color-fg)] underline decoration-dashed decoration-[var(--color-muted)] underline-offset-4 hover:text-[var(--color-accent)] hover:decoration-solid"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
          <a
            href={`https://github.com/${AUTHOR.github}`}
            class="text-[var(--color-fg)] underline decoration-dashed decoration-[var(--color-muted)] underline-offset-4 hover:text-[var(--color-accent)] hover:decoration-solid"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
        </div>

        <p class="mt-6 text-sm text-[var(--color-muted)]">{awayFromKeyboard}</p>

        <section class="mt-12">
          <h2
            id="areas-of-expertise"
            class="scroll-mt-28 font-sans text-2xl font-semibold tracking-tight"
          >
            Areas of Expertise
          </h2>
          <div class="cv-skills-grid mt-6">
            {
              expertise.map((area) => (
                <div class="cv-skill-card">
                  <strong>{area.title}</strong>
                  <p>{area.description}</p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="mt-12">
          <h2
            id="experience"
            class="scroll-mt-28 font-sans text-2xl font-semibold tracking-tight"
          >
            Experience
          </h2>
          <div class="cv-experience mt-6">
            {
              experience.map((job) => (
                <div class="cv-job" id={jobSlug(job)}>
                  <div class="cv-job-header">
                    <h3 class="scroll-mt-28 font-sans text-lg font-semibold tracking-tight">
                      {job.company}
                      {job.team && <span class="cv-team">{job.team}</span>}
                    </h3>
                    {job.dates && <span class="cv-date">{job.dates}</span>}
                  </div>
                  {job.title && (
                    <p class="text-sm text-[var(--color-muted)]">{job.title}</p>
                  )}
                  {job.roles && job.roles.length > 0 && (
                    <div class="cv-roles">
                      {job.roles.map((role) => (
                        <div class="cv-role" id={jobSlug(job, role)}>
                          <div class="cv-job-header">
                            <h4 class="scroll-mt-28 font-sans text-base font-semibold tracking-tight">
                              {role.team}
                            </h4>
                            {role.dates && (
                              <span class="cv-date">{role.dates}</span>
                            )}
                          </div>
                          {role.title && (
                            <p class="text-sm text-[var(--color-muted)]">
                              {role.title}
                            </p>
                          )}
                          {role.highlights && role.highlights.length > 0 && (
                            <ul>
                              {role.highlights.map((item) => (
                                <li>{item}</li>
                              ))}
                            </ul>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                  {job.highlights && job.highlights.length > 0 && (
                    <ul class:list={[job.roles?.length && "mt-5"]}>
                      {job.highlights.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))
            }
          </div>
        </section>

        <section class="mt-12">
          <h2
            id="skills"
            class="scroll-mt-28 font-sans text-2xl font-semibold tracking-tight"
          >
            Skills
          </h2>
          <div class="cv-tags mt-5">
            {skills.map((skill) => <span class="cv-tag">{skill}</span>)}
          </div>
        </section>

        <section class="mt-12 pb-4">
          <h2
            id="open-source--community"
            class="scroll-mt-28 font-sans text-2xl font-semibold tracking-tight"
          >
            Open Source
          </h2>
          <div class="mt-5 space-y-4 text-[1.0625rem] leading-relaxed">
            {
              openSource.map((item) => (
                <p>
                  <strong>
                    <a
                      href={item.href}
                      class="text-[var(--color-accent)] underline decoration-[color-mix(in_oklab,var(--color-accent)_40%,transparent)] underline-offset-4 hover:decoration-[var(--color-accent)]"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {item.name}
                    </a>
                  </strong>
                  {" — "}
                  {item.role}. {item.description}
                </p>
              ))
            }
          </div>
        </section>
      </article>

      <aside class="sticky top-24 self-start pt-2">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>
</BaseLayout>
