---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts, slugifyTag } from "../../utils/posts";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="Tags" description="Browse blog posts by tag.">
  <div class="container-page">
    <header class="mb-10 max-w-2xl">
      <h1 class="font-sans text-3xl font-semibold tracking-tight sm:text-4xl">Tags</h1>
      <p class="mt-3 text-[var(--color-muted)] leading-relaxed">
        Topics covered across the blog.
      </p>
    </header>

    <ul class="flex flex-wrap gap-3">
      {
        [...tags.entries()].map(([tag, count]) => (
          <li>
            <a
              href={`/tags/${slugifyTag(tag)}/`}
              class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3.5 py-2 text-sm transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
            >
              <span>#{tag}</span>
              <span class="text-[var(--color-muted)]">{count}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
