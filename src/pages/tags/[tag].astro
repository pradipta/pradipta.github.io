---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, slugifyTag } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagMap = new Map<string, typeof posts>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const key = slugifyTag(tag);
      const list = tagMap.get(key) ?? [];
      list.push(post);
      tagMap.set(key, list);
    }
  }

  return [...tagMap.entries()].map(([slug, taggedPosts]) => {
    const label =
      taggedPosts
        .flatMap((p) => p.data.tags)
        .find((t) => slugifyTag(t) === slug) ?? slug;

    return {
      params: { tag: slug },
      props: { tag: label, posts: taggedPosts },
    };
  });
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag}`}
  description={`Posts tagged ${tag}.`}
>
  <div class="container-page">
    <header class="mb-10 max-w-2xl">
      <p class="text-sm text-[var(--color-muted)]">
        <a href="/tags/" class="hover:text-[var(--color-accent)]">Tags</a>
      </p>
      <h1 class="mt-2 font-sans text-3xl font-semibold tracking-tight sm:text-4xl">
        #{tag}
      </h1>
      <p class="mt-3 text-[var(--color-muted)]">
        {posts.length} {posts.length === 1 ? "post" : "posts"}
      </p>
    </header>

    <div>
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
