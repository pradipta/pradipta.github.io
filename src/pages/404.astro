---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The page you’re looking for doesn’t exist.">
  <div class="container-page">
    <div class="mx-auto max-w-lg py-20 text-center">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-[var(--color-muted)]">
        404
      </p>
      <h1 class="mt-4 font-sans text-3xl font-semibold tracking-tight">
        Page not found
      </h1>
      <p class="mt-3 text-[var(--color-muted)] leading-relaxed">
        That URL doesn’t match anything on this site. It may have moved, or the link
        might be outdated.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="inline-flex rounded-md bg-[var(--color-fg)] px-4 py-2.5 text-sm font-medium text-[var(--color-bg)] hover:opacity-90"
        >
          Go home
        </a>
        <a
          href="/blog/"
          class="inline-flex rounded-md border border-[var(--color-border)] px-4 py-2.5 text-sm text-[var(--color-fg)] hover:border-[var(--color-accent)]"
        >
          Browse blog
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
