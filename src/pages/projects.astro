---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects"
  description="Selected work, writing, and experiments from Pradipta Sarma."
>
  <div class="container-page">
    <header class="mb-10 max-w-2xl">
      <h1 class="font-sans text-3xl font-semibold tracking-tight sm:text-4xl">
        Projects
      </h1>
      <p class="mt-3 text-[var(--color-muted)] leading-relaxed">
        Selected work and writing — production systems, tooling notes, and personal
        experiments.
      </p>
    </header>

    <div>
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</BaseLayout>
