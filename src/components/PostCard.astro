---
import type { BlogPost } from "../utils/posts";
import { getPostPath, slugifyTag } from "../utils/posts";
import { formatDate, getReadingTime } from "../utils/readingTime";

interface Props {
  post: BlogPost;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const href = getPostPath(post);
const readingTime = getReadingTime(post.body ?? "");
const image = post.data.img ? `/assets/img/${post.data.img}` : undefined;
const description =
  post.data.description ||
  (post.body ?? "").replace(/[#>*_`\[\]]+/g, " ").trim().slice(0, 140);
---

<article
  class:list={[
    "group border-b border-[var(--color-border)] py-8 first:pt-0 last:border-b-0",
    featured && image && "sm:grid sm:grid-cols-[200px_1fr] sm:gap-8 sm:items-start",
  ]}
>
  {
    featured && image && (
      <a href={href} class="mb-4 block overflow-hidden rounded-lg sm:mb-0" tabindex="-1" aria-hidden="true">
        <img
          src={image}
          alt=""
          class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }
  <div>
    <p class="mb-2 flex flex-wrap items-center gap-x-2 text-sm text-[var(--color-muted)]">
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime} min read</span>
    </p>
    <h2 class="font-sans text-xl font-semibold tracking-tight sm:text-2xl">
      <a href={href} class="hover:text-[var(--color-accent)]">{post.data.title}</a>
    </h2>
    {
      description && (
        <p class="mt-2 max-w-2xl text-[var(--color-muted)] leading-relaxed">
          {description}
        </p>
      )
    }
    {
      post.data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 4).map((tag) => (
            <li>
              <a
                href={`/tags/${slugifyTag(tag)}/`}
                class="text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)]"
              >
                #{tag}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
